{
    "name": "geo-csv-tsv-toolkit",
    "version": "2.0.0",
    "type": "module",
    "description": "FlowMCP geo add-on (In-Memory): load geo CSV/TSV files from a URL with mandatory parse config, validate-on-load, and the shared geo method family (nearPoint, inBoundingBox, byType) returning a normalized RFC 7946 FeatureCollection — no SQLite, no file seal",
    "main": "src/index.mjs",
    "license": "MIT",
    "author": "FlowMCP",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/FlowMCP/geo-csv-tsv-toolkit.git"
    },
    "bugs": {
        "url": "https://github.com/FlowMCP/geo-csv-tsv-toolkit/issues"
    },
    "homepage": "https://github.com/FlowMCP/geo-csv-tsv-toolkit#readme",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
        "test:coverage:src": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --passWithNoTests",
        "test:manual": "node tests/manual/run-all.mjs"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "jest": "^30.0.0"
    }
}
